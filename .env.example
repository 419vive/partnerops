# Copy this file to .env.local for host development. Docker Compose supplies its
# own PostgreSQL URL. Replace every CHANGE_ME value outside a synthetic demo.
APP_ENV=dev
APP_SECRET=CHANGE_ME_WITH_A_LONG_RANDOM_VALUE
APP_TIMEZONE=Asia/Taipei
DATABASE_URL="postgresql://partnerops:partnerops@127.0.0.1:5432/partnerops?serverVersion=16&charset=utf8"
API_TOKEN_PEPPER=CHANGE_ME_WITH_AN_INDEPENDENT_RANDOM_VALUE
DEFAULT_URI=http://localhost:8080
# Keep empty for direct local traffic. Production must list only the actual
# edge/load-balancer addresses or CIDRs, separated by commas.
SYMFONY_TRUSTED_PROXIES=
