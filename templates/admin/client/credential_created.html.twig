{% extends 'base.html.twig' %}

{% block title %}API 憑證已建立 · {{ app_name }}{% endblock %}
{% block context_label %}密鑰只會顯示這一次。{% endblock %}

{% block body %}
    <header class="page-heading"><div><span class="eyebrow">Credential issued</span><h1>立即保存<em>密鑰</em></h1><p>{{ client.name }} · {{ credential.name }}</p></div></header>
    <section class="form-card token-card" aria-labelledby="token-title">
        <h2 id="token-title">一次性 API Token</h2>
        <p class="flash flash--warning" role="alert">離開這一頁後，系統無法再次顯示完整密鑰。請存入公司的秘密管理工具，不要貼到聊天、截圖或提交到 Git。</p>
        <code class="token-value">{{ token }}</code>
        <div class="form-actions"><a class="button button--signal" href="{{ path('app_admin_client_show', {publicId: client.publicId}) }}">我已安全保存</a></div>
    </section>
{% endblock %}
